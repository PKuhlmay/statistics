{
  "name": "statistic-learning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "lint": "oxlint app/ server/ nuxt.config.ts",
    "lint:fix": "oxlint --fix app/ server/ nuxt.config.ts",
    "lint:eslint": "eslint .",
    "format": "oxfmt --write app/ server/ nuxt.config.ts",
    "format:check": "oxfmt --check app/ server/ nuxt.config.ts",
    "typecheck": "nuxt typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs}": "oxlint --fix",
    "*.{js,ts,vue,mjs,json,css,html}": "oxfmt --write"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "chart.js": "^4.5.1",
    "katex": "^0.16.45",
    "nuxt": "^3.21.2",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/hints": "^1.0.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.0.1",
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/katex": "^0.16.7",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vueuse/nuxt": "^14.2.1",
    "husky": "^9.1.7",
    "knip": "^6.6.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
